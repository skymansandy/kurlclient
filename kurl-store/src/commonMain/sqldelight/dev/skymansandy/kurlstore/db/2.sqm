PRAGMA foreign_keys = OFF;

-- Recreate CollectionFolder with self-referential FK CASCADE
CREATE TABLE CollectionFolder_new (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    parent_id INTEGER REFERENCES CollectionFolder_new(id) ON DELETE CASCADE,
    created_at INTEGER NOT NULL
);
INSERT INTO CollectionFolder_new (id, name, parent_id, created_at)
    SELECT id, name, parent_id, created_at FROM CollectionFolder;
DROP TABLE CollectionFolder;
ALTER TABLE CollectionFolder_new RENAME TO CollectionFolder;

-- Recreate SavedRequest with FK CASCADE; use url as name for existing rows
CREATE TABLE SavedRequest_new (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    folder_id INTEGER REFERENCES CollectionFolder(id) ON DELETE CASCADE,
    url TEXT NOT NULL,
    method TEXT NOT NULL,
    headers TEXT NOT NULL,
    params TEXT NOT NULL,
    body TEXT NOT NULL,
    created_at INTEGER NOT NULL
);
INSERT INTO SavedRequest_new (id, name, folder_id, url, method, headers, params, body, created_at)
    SELECT id, url, folder_id, url, method, headers, params, body, created_at FROM SavedRequest;
DROP TABLE SavedRequest;
ALTER TABLE SavedRequest_new RENAME TO SavedRequest;

PRAGMA foreign_keys = ON;